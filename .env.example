# 拷贝为 .env 后由部署工具注入，或直接在进程环境导出（勿将真实密钥提交仓库）
# 运行模式：development | production
# DJANGO_ENV=development

# ---------- 生产必填（DJANGO_ENV=production）----------
# DJANGO_SECRET_KEY=
# DJANGO_ALLOWED_HOSTS=your.domain.com,www.your.domain.com

# 置于 HTTPS 反向代理之后时启用（Nginx/Ingress 转发 X-Forwarded-Proto）
# DJANGO_BEHIND_HTTPS_PROXY=1
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your.domain.com,https://www.your.domain.com

# 可选：强制 301 跳转到 HTTPS（代理已终结 TLS 时通常仍建议开启）
# DJANGO_SECURE_SSL_REDIRECT=1
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_PRELOAD=0

# 仅排查问题时临时开启（生产勿开）
# DJANGO_DEBUG=0

# 密钥强度校验（1=开启，开发/内网测试可设 0）
# DJANGO_SECRET_KEY_STRENGTH_CHECK=1

# ---------- 数据库 ----------
# sqlite（默认）：可指定路径
# DJANGO_DB_ENGINE=sqlite3
# DJANGO_SQLITE_PATH=/data/gaussdbom/db.sqlite3

# PostgreSQL
# DJANGO_DB_ENGINE=postgresql
# DJANGO_DB_NAME=gaussdbom
# DJANGO_DB_USER=gaussdbom
# DJANGO_DB_PASSWORD=
# DJANGO_DB_HOST=127.0.0.1
# DJANGO_DB_PORT=5432
# DJANGO_DB_CONN_MAX_AGE=60

# ---------- 日志 ----------
# DJANGO_LOG_LEVEL=INFO
